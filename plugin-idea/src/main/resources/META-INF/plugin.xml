<idea-plugin>
    <id>com.codeforge.idea</id>
    <name>CodeForge</name>
    <version>1.0.0</version>
    <vendor email="support@codeforge.dev" url="https://github.com/codeforge">CodeForge</vendor>

    <description><![CDATA[
        <b>CodeForge</b> — 锻造每一行代码<br/><br/>
        AI 编程助手，聚合国内外 16+ 主流大模型，在 IDE 内自由切换。<br/><br/>
        <b>核心功能：</b>
        <ul>
            <li>🔥 AI 聊天面板 — 对话式编程，边聊边写</li>
            <li>⚡ 一键切换模型 — DeepSeek / GPT / Claude / Qwen / GLM 等</li>
            <li>🛠️ 代码操作 — 解释、优化、审查、生成测试</li>
            <li>📋 代码 Apply — AI 修改直接写入文件</li>
        </ul>
        <b>支持模型：</b>DeepSeek、通义千问、智谱GLM、Kimi、MiniMax、文心一言、
        豆包、OpenAI GPT、Anthropic Claude、Google Gemini、Mistral、Groq、xAI Grok 等
    ]]></description>

    <!-- 依赖 IntelliJ Platform 基础模块 -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ===== 侧边栏聊天窗口 ===== -->
        <toolWindow
                id="CodeForge"
                anchor="right"
                secondary="false"
                canCloseContents="false"
                factoryClass="com.codeforge.plugin.idea.toolwindow.CodeForgeToolWindowFactory"
                icon="/icons/forge_13.svg"/>

        <!-- ===== 底部状态栏模型切换 Widget ===== -->
        <statusBarWidgetFactory
                id="CodeForgeModelStatusBar"
                implementation="com.codeforge.plugin.idea.statusbar.ModelStatusBarFactory"
                order="first"/>

        <!-- ===== 设置页（File → Settings → Tools → CodeForge）===== -->
        <applicationConfigurable
                parentId="tools"
                instance="com.codeforge.plugin.idea.settings.CodeForgeSettingsConfigurable"
                id="com.codeforge.idea.settings"
                displayName="CodeForge"/>

        <!-- ===== 持久化设置存储 ===== -->
        <applicationService
                serviceImplementation="com.codeforge.plugin.idea.settings.CodeForgeSettings"/>

        <!-- ===== LLM 服务（应用级单例，直接调用内置 Provider）===== -->
        <applicationService
                serviceImplementation="com.codeforge.plugin.idea.service.LlmService"/>

        <!-- ===== 行内代码补全 Provider ===== -->
        <inlineCompletion.provider
                implementation="com.codeforge.plugin.idea.completion.CodeForgeInlineCompletionProvider"/>

    </extensions>

    <actions>
        <!-- ===== 编辑器右键菜单（置顶） ===== -->
        <group id="CodeForge.EditorMenu" text="CodeForge" description="CodeForge AI 操作" popup="true"
               icon="/icons/forge_16.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>

            <action id="CodeForge.Chat"
                    class="com.codeforge.plugin.idea.actions.ChatAction"
                    text="Chat"
                    description="打开 CodeForge 聊天面板"/>

            <action id="CodeForge.CustomPrompt"
                    class="com.codeforge.plugin.idea.actions.CustomPromptAction"
                    text="Run Custom Prompt Template"
                    description="运行自定义 Prompt 模板"/>

            <action id="CodeForge.FindProblem"
                    class="com.codeforge.plugin.idea.actions.FindProblemAction"
                    text="Find Problem"
                    description="让 AI 查找代码中的潜在问题"/>

            <action id="CodeForge.ExplainCode"
                    class="com.codeforge.plugin.idea.actions.ExplainCodeAction"
                    text="Explain"
                    description="让 AI 解释选中的代码"/>

            <action id="CodeForge.OptimizeCode"
                    class="com.codeforge.plugin.idea.actions.OptimizeCodeAction"
                    text="Optimize"
                    description="让 AI 优化选中的代码"/>

            <action id="CodeForge.Generate"
                    class="com.codeforge.plugin.idea.actions.GenerateAction"
                    text="Generate"
                    description="让 AI 根据上下文生成代码">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt K"/>
            </action>

            <action id="CodeForge.AddComments"
                    class="com.codeforge.plugin.idea.actions.AddCommentsAction"
                    text="Add Comments"
                    description="让 AI 为选中的代码添加注释">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt SLASH"/>
            </action>

            <action id="CodeForge.AddDocstring"
                    class="com.codeforge.plugin.idea.actions.AddDocstringAction"
                    text="Add Docstring"
                    description="让 AI 为选中的代码添加文档注释">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt 3"/>
            </action>

            <action id="CodeForge.GenerateTest"
                    class="com.codeforge.plugin.idea.actions.GenerateTestAction"
                    text="Generate Unit Test"
                    description="让 AI 为选中的代码生成单元测试"/>

            <action id="CodeForge.ReviewCode"
                    class="com.codeforge.plugin.idea.actions.ReviewCodeAction"
                    text="Review Code"
                    description="让 AI 审查选中的代码，找出潜在问题"/>

            <!-- A7：行内 AI 编辑（选中代码后 Alt+A 触发） -->
            <action id="CodeForge.InlineEdit"
                    class="com.codeforge.plugin.idea.actions.InlineEditAction"
                    text="Inline Edit"
                    description="选中代码后弹出 AI 编辑指令框，修改结果以 InlineDiff 展示">
                <keyboard-shortcut keymap="$default" first-keystroke="alt A"/>
            </action>
        </group>
        <!-- ===== Git 深度集成 Actions（T18）===== -->
        <!-- Generate Commit Message：加入 VCS 操作组 + 编辑器右键菜单 -->
        <group id="CodeForge.GitGroup" text="CodeForge Git" description="CodeForge Git AI 工具" popup="true"
               icon="/icons/forge_16.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
            <add-to-group group-id="VcsGroups" anchor="last"/>

            <action id="CodeForge.GenerateCommitMessage"
                    class="com.codeforge.plugin.idea.actions.GenerateCommitMessageAction"
                    text="Generate Commit Message"
                    description="使用 AI 为 staged 变更生成 Conventional Commit 格式的提交信息">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt M"/>
            </action>

            <action id="CodeForge.GeneratePRDescription"
                    class="com.codeforge.plugin.idea.actions.GeneratePRDescriptionAction"
                    text="Generate PR Description"
                    description="使用 AI 为当前分支生成 PR 描述，并复制到剪贴板">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt P"/>
            </action>
        </group>
    </actions>

</idea-plugin>
